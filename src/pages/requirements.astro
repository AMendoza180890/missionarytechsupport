---
import Layout from "~/layouts/Layout.astro";
import Section from "~/components/Section.astro";
import Newsletter from "~/components/Newsletter.astro";
---

<Layout
    title="Requirements"
    pageTitle="Requirements"
    description="This page contains a form to learn more about the requirements for your future project"
>
    <Section class:list={"bg-white"}>
        <section class="max-w-5xl mx-auto w-full">
            <div
                slot="hero-content-left"
                class="prose max-w-max max-lg:order-1 mb-8"
            >
                <h1 class="font-black">Requirements</h1>
                <p>
                    We would like to know what you need for your project. Please
                    complete the following form and we will get in touch with
                    you as soon as possible. We look forward to hearing from
                    you.
                </p>
            </div>

            <form
                action="/thank-you"
                method="POST"
                class="mt-8 flex flex-col gap-6 max-w-3xl border border-gray-200 p-6 md:p-8 rounded-xl shadow-sm bg-gray-50/50"
                enctype="multipart/form-data"
            >
                <!-- 1. Domain -->
                <div class="flex items-center gap-3">
                    <label for="hasDomain" class="font-medium text-gray-700"
                        >1. Do you have a domain already? (Yes/No)</label
                    >
                    <input
                        type="checkbox"
                        id="hasDomain"
                        name="hasDomain"
                        class="w-5 h-5 accent-brand-green"
                    />
                </div>

                <!-- 2. Host -->
                <div class="flex items-center gap-3">
                    <label for="hasHost" class="font-medium text-gray-700"
                        >2. Do you have a host? (Yes/No)</label
                    >
                    <input
                        type="checkbox"
                        id="hasHost"
                        name="hasHost"
                        class="w-5 h-5 accent-brand-green"
                    />
                </div>

                <!-- 3. Photos -->
                <div class="flex flex-col gap-2">
                    <label
                        for="photosPreference"
                        class="font-medium text-gray-700"
                        >3. Do you have photos to add or do you prefer stock
                        photos?</label
                    >
                    <input
                        type="text"
                        id="photosPreference"
                        name="photosPreference"
                        class="border border-gray-300 rounded-md p-2 focus:ring-brand-green focus:border-brand-green"
                    />
                </div>

                <!-- 4. Logo -->
                <div class="flex flex-col gap-2">
                    <label for="logoUpload" class="font-medium text-gray-700"
                        >4. Upload logo here:</label
                    >
                    <input
                        type="file"
                        id="logoUpload"
                        name="logoUpload"
                        class="file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-semibold file:bg-brand-green file:text-white hover:file:bg-green-700"
                    />
                </div>

                <!-- 5. Color Scheme -->
                <div class="flex flex-col gap-2">
                    <label for="colorScheme" class="font-medium text-gray-700"
                        >5. Add color scheme info here:</label
                    >
                    <textarea
                        id="colorScheme"
                        name="colorScheme"
                        rows="3"
                        class="border border-gray-300 rounded-md p-2 focus:ring-brand-green focus:border-brand-green"
                    ></textarea>
                </div>

                <!-- 6. Font Type -->
                <div class="flex flex-col gap-2">
                    <label for="fontType" class="font-medium text-gray-700"
                        >6. Preferred font type:</label
                    >
                    <textarea
                        id="fontType"
                        name="fontType"
                        rows="2"
                        class="border border-gray-300 rounded-md p-2 focus:ring-brand-green focus:border-brand-green"
                    ></textarea>
                </div>

                <!-- 7. Example Websites -->
                <div class="flex flex-col gap-2">
                    <label
                        for="exampleWebsites"
                        class="font-medium text-gray-700"
                        >7. Add example websites for theme:</label
                    >
                    <input
                        type="text"
                        id="exampleWebsites"
                        name="exampleWebsites"
                        class="border border-gray-300 rounded-md p-2 focus:ring-brand-green focus:border-brand-green"
                    />
                </div>

                <!-- 8. Page Type Preference -->
                <div class="flex flex-col gap-2">
                    <label
                        for="pagePreference"
                        class="font-medium text-gray-700"
                        >8. Do you prefer a landing page or separate pages for
                        each section?</label
                    >
                    <select
                        id="pagePreference"
                        name="pagePreference"
                        class="border border-gray-300 rounded-md p-2 focus:ring-brand-green focus:border-brand-green bg-white"
                    >
                        <option value="" disabled selected
                            >Select an option</option
                        >
                        <option value="landing_page">Landing Page</option>
                        <option value="separate_pages">Separate Pages</option>
                    </select>
                </div>

                <!-- 9. Menu Tabs -->
                <div class="flex flex-col gap-2">
                    <label for="menuTabs" class="font-medium text-gray-700"
                        >9. What tabs do you want the menu bar to have?</label
                    >
                    <textarea
                        id="menuTabs"
                        name="menuTabs"
                        rows="3"
                        class="border border-gray-300 rounded-md p-2 focus:ring-brand-green focus:border-brand-green"
                    ></textarea>
                </div>

                <!-- 10. Basic Functions -->
                <div class="flex flex-col gap-2">
                    <label
                        for="basicFunctions"
                        class="font-medium text-gray-700"
                        >10. What basic functions do you want your site to have?</label
                    >
                    <textarea
                        id="basicFunctions"
                        name="basicFunctions"
                        rows="3"
                        class="border border-gray-300 rounded-md p-2 focus:ring-brand-green focus:border-brand-green"
                    ></textarea>
                </div>

                <!-- 12. Script Upload -->
                <div class="flex flex-col gap-2">
                    <label for="scriptUpload" class="font-medium text-gray-700"
                        >12. If you have a script for the website, please attach
                        here:</label
                    >
                    <input
                        type="file"
                        id="scriptUpload"
                        name="scriptUpload"
                        class="file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-semibold file:bg-brand-green file:text-white hover:file:bg-green-700"
                    />
                </div>

                <!-- 13. General Tech Support Needs -->
                <div class="flex flex-col gap-2">
                    <label
                        for="techSupportNeeds"
                        class="font-medium text-gray-700"
                        >13. Please list other general tech support needs here,
                        if any:</label
                    >
                    <textarea
                        id="techSupportNeeds"
                        name="techSupportNeeds"
                        rows="3"
                        class="border border-gray-300 rounded-md p-2 focus:ring-brand-green focus:border-brand-green"
                    ></textarea>
                </div>

                <!-- 14. Additional Notes -->
                <div class="flex flex-col gap-2">
                    <label
                        for="additionalNotes"
                        class="font-medium text-gray-700"
                        >14. Additional notes:</label
                    >
                    <textarea
                        id="additionalNotes"
                        name="additionalNotes"
                        rows="3"
                        class="border border-gray-300 rounded-md p-2 focus:ring-brand-green focus:border-brand-green"
                    ></textarea>
                </div>

                <!-- 15. Photo/Storytelling Support -->
                <div class="flex items-center gap-3">
                    <label
                        for="needPhotoStory"
                        class="font-medium text-gray-700"
                        >15. Do you need Photo/storytelling support? (Yes/No)</label
                    >
                    <input
                        type="checkbox"
                        id="needPhotoStory"
                        name="needPhotoStory"
                        class="w-5 h-5 accent-brand-green"
                    />
                </div>

                <!-- 16. Kind of Service -->
                <div class="flex flex-col gap-2">
                    <label for="serviceType" class="font-medium text-gray-700"
                        >16. What kind of service?</label
                    >
                    <select
                        id="serviceType"
                        name="serviceType"
                        class="border border-gray-300 rounded-md p-2 focus:ring-brand-green focus:border-brand-green bg-white"
                    >
                        <option value="" disabled selected
                            >Select an option</option
                        >
                        <option value="photo">Photo</option>
                        <option value="storytellings">Storytellings</option>
                        <option value="both">Both</option>
                    </select>
                </div>

                <!-- 17. Multiselect Photography -->
                <div class="flex flex-col gap-2">
                    <label class="font-medium text-gray-700"
                        >17. If need photography, click all that apply:</label
                    >
                    <div class="flex flex-col gap-2 ml-4">
                        <label class="flex items-center gap-2">
                            <input
                                type="checkbox"
                                name="photographyNeed"
                                value="specific_event"
                                class="w-4 h-4 accent-brand-green"
                            />
                            <span class="text-gray-700">a. Specific event</span>
                        </label>
                        <label class="flex items-center gap-2">
                            <input
                                type="checkbox"
                                name="photographyNeed"
                                value="candids"
                                class="w-4 h-4 accent-brand-green"
                            />
                            <span class="text-gray-700"
                                >b. Candids of ministry</span
                            >
                        </label>
                        <label class="flex items-center gap-2">
                            <input
                                type="checkbox"
                                name="photographyNeed"
                                value="portraits"
                                class="w-4 h-4 accent-brand-green"
                            />
                            <span class="text-gray-700"
                                >c. Portraits (staff, families, etc.)</span
                            >
                        </label>
                        <label class="flex items-center gap-2">
                            <input
                                type="checkbox"
                                name="photographyNeed"
                                value="facility"
                                class="w-4 h-4 accent-brand-green"
                            />
                            <span class="text-gray-700">d. Facility</span>
                        </label>
                    </div>
                </div>

                <!-- 18. Multiselect Storytelling -->
                <div class="flex flex-col gap-2">
                    <label class="font-medium text-gray-700"
                        >18. If need storytelling, click all that apply:</label
                    >
                    <div class="flex flex-col gap-2 ml-4">
                        <label class="flex items-center gap-2">
                            <input
                                type="checkbox"
                                name="storytellingNeed"
                                value="blog_updates"
                                class="w-4 h-4 accent-brand-green"
                            />
                            <span class="text-gray-700">a. Blog updates</span>
                        </label>
                        <label class="flex items-center gap-2">
                            <input
                                type="checkbox"
                                name="storytellingNeed"
                                value="newsletters"
                                class="w-4 h-4 accent-brand-green"
                            />
                            <span class="text-gray-700">b. Newsletters</span>
                        </label>
                        <label class="flex items-center gap-2">
                            <input
                                type="checkbox"
                                name="storytellingNeed"
                                value="interviewing"
                                class="w-4 h-4 accent-brand-green"
                            />
                            <span class="text-gray-700"
                                >c. Interviewing for testimonials</span
                            >
                        </label>
                        <label class="flex items-center gap-2">
                            <input
                                type="checkbox"
                                name="storytellingNeed"
                                value="social_media"
                                class="w-4 h-4 accent-brand-green"
                            />
                            <span class="text-gray-700">d. Social media</span>
                        </label>
                        <label class="flex items-center gap-2">
                            <input
                                type="checkbox"
                                name="storytellingNeed"
                                value="script"
                                class="w-4 h-4 accent-brand-green"
                            />
                            <span class="text-gray-700">e. Script</span>
                        </label>
                    </div>
                </div>

                <div class="mt-8 flex justify-end">
                    <button
                        type="submit"
                        class="bg-brand-green text-white px-8 py-3 rounded-md font-bold hover:bg-green-700 transition shadow-md"
                        >Submit</button
                    >
                </div>
            </form>
        </section>
    </Section>

    <Section class:list={"container py-1 lg:py-1"} contain={false}>
        <Newsletter />
    </Section>
</Layout>

<style>
    .gridImg {
        border: 1px solid white;
        border-radius: 10px;
    }
</style>
